Mods: {
	LK_Ugrumiy_WP: {
		NPCs: {
			JohnNPC: {
				// DeathMessage: Mods.LK_Ugrumiy_WP.NPCs.JohnNPC.DeathMessage
				DisplayName: Джон
			}

			CowNPC: {
				DisplayName: Корова

				TownNPCMood: {
					// Content: I am content.
					// NoHome: I hate not having a home.
					// FarFromHome: I am too far from home.
					// LoveSpace: I love having so much space.
					// DislikeCrowded: I dislike how crowded I am.
					// HateCrowded: I hate how crowded I am.
					// LikeNPC_Princess: I like {NPCName}.
					// Princess_LovesNPC: I like {NPCName}.
				}
			}
		}

		Dialogue: {
			JohnNPC: {
				Angry: Это МОЯ шляпа! Верни её или я заберу силой!
				AngryChat: Джону не нравится, что вы носите его шляпу...
				Standard1: Пещеры... они меняют человека. Поверь мне.
				Standard2: Я видел тут такое, во что ты не поверишь.
				Standard3: Не обращай на меня внимания. Просто прохожу мимо.
			}

			CowNPC: {
				Standard1: Муу... то есть, ФЫРК! Я БЫК, понятно?!
				Standard2: Хватит называть меня коровой. Я ПОХОЖ на корову?! ...Не отвечай.
				Standard3: Я БЫК. Б-Ы-К. Рога? Чисто декоративные. Вымя? ...Не твоё дело.
				Standard4: Да, я даю молоко. Быки тоже так могут. На дворе 2026, хватит осуждать.
				Standard5: Проводник опять пытается меня погладить. Ещё раз и я его забодаю.
				Standard6: Я пришёл сюда только потому, что учуял сено. Не обольщайся.
				Cooldown: Эй-эй, полегче! Я не машина. Дай мне минутку...
				Milk1: Вот. Доволен? ...Не смотри на меня так.
				Milk2: *неловкое мычание* ...Мы об этом никогда не будем говорить.
				Milk3: Бычье молоко — деликатес в некоторых культурах! ...Наверное.
				Milk4: Клянусь, это последний раз. ...Я так говорил и в прошлый раз.
			}
		}

		Bestiary.CowNPC: "'Корова', которая утверждает, что она бык. Даёт молоко, если у вас есть сено. Не спрашивайте, откуда оно берётся."

		Items: {
			ibp3000: {
				DisplayName: ИБП-3000
				Tooltip:
					'''
					Метательная железная звезда, заряженная энергией падающих звёзд
					Наносит 69 урона за попадание
					'Сияй ярко, как смертоносная звезда'
					'''
			}

			SpookyCandy: {
				DisplayName: Жуткая конфета
				Tooltip:
					'''
					Совершенно обычная конфетка. Не о чем беспокоиться!
					'На вкус как счастье и радуга'
					'''
			}

			FatBurger: {
				DisplayName: Бургер жирности
				Tooltip:
					'''
					Подозрительно большой бургер, сочащийся жиром
					Восстанавливает 30 ХП при использовании
					'Ещё один не повредит, да?'
					'''
			}

			DietPill: {
				DisplayName: Диетическая таблетка
				Tooltip:
					'''
					Помогает вернуться в форму
					'Проконсультируйтесь с врачом перед применением'
					'''
			}

			Cherry: {
				DisplayName: Вишня
				Tooltip:
					'''
					Крайне редкая вишня, полностью восстанавливающая ХП
					'Один укус — и ты снова в строю'
					'''
			}

			JohnsHat: {
				DisplayName: Шапка Джона
				Tooltip:
					'''
					'Поношенная кепка с историей...'
					+10% урона по всем врагам
					+5% шанс критического удара
					Джон будет охотиться на тебя, если наденешь это...
					'''
			}

			CursedBandle: {
				DisplayName: Проклятый браслет
				Tooltip:
					'''
					'Ты чувствуешь, как что-то тёмное берёт контроль...'
					Проклятие утраты
					Твоё тело двигается само по себе
					'''
			}

			SlimeShotgun: {
				DisplayName: Слизневый дробовик
				Tooltip:
					'''
					Выстреливает очередью из 5 липких слизневых сгустков
					Слизь создаёт лужи на поверхностях, замедляющие врагов
					Прямые попадания также замедляют на 2 секунды
					Не требует боеприпасов
					'Кто это зарядил?!'
					'''
			}

			SlimeMinigun: {
				DisplayName: Слизневый миниган
				Tooltip:
					'''
					Быстро стреляет липкими слизневыми сгустками
					Слизь создаёт лужи на поверхностях, замедляющие врагов
					Не требует боеприпасов
					'Бррррр... *шлёп шлёп шлёп*'
					'''
			}

			CowBell: {
				DisplayName: Коровий колокольчик
				Tooltip: "'Позвоните, чтобы призвать корову... или быка?'"
			}

			CowMilk: {
				DisplayName: Молоко
				Tooltip:
					'''
					Просто обычное молоко, наверное.....
					Восстанавливает 50 ХП и даёт эффект Сытости
					'Не спрашивай, откуда оно'
					'''
			}
		}

		Buffs: {
			CherryCooldown: {
				DisplayName: Откат вишни
				Description: Ты ещё не можешь съесть вишню...
			}
		}

		Projectiles: {
			Ibp3000Projectile.DisplayName: ИБП-3000
			SlimeGlob.DisplayName: Слизневый сгусток
			SlimePuddle.DisplayName: Слизневая лужа
		}
	}
}
