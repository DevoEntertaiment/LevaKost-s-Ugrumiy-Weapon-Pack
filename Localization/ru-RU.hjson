Mods: {
	LK_Ugrumiy_WP: {
		NPCs: {
			JohnNPC.DisplayName: Джон

			CowNPC: {
				DisplayName: Корова

				TownNPCMood: {
					Content: Мне здесь нравится.
					NoHome: Ненавижу жить без дома.
					FarFromHome: Я слишком далеко от дома.
					LoveSpace: Обожаю, когда много места.
					DislikeCrowded: Слишком тесно тут.
					HateCrowded: Я ненавижу эту толкучку!
					LikeNPC_Princess: Мне нравится {NPCName}.
					Princess_LovesNPC: Мне нравится {NPCName}.
				}
			}

			MechanicMerriweatherNPC: {
				DisplayName: Механик-Мерриуэзер

				TownNPCMood: {
					Content: Провода гудят — значит, всё идёт по плану.
					NoHome: Без мастерской я ничего не смогу собрать!
					FarFromHome: Я слишком далеко от своего верстака.
					LoveSpace: Сколько места — можно проложить километры кабеля!
					DislikeCrowded: Слишком много людей — все спотыкаются о мои провода.
					HateCrowded: В этой толпе я даже паять не могу!
					LikeNPC_Princess: Мне нравится {NPCName}.
					Princess_LovesNPC: Мне нравится {NPCName}.
					// LikeBiome: Мне нравится {BiomeName}.
					// DislikeBiome: Мне не нравится {BiomeName}.
					// LoveNPC: Я люблю {NPCName}.
					// LikeNPC: Мне нравится {NPCName}.
					// DislikeNPC: Мне не нравится {NPCName}.
					// HateNPC: Я ненавижу {NPCName}.
				}
			}
		}

		Dialogue: {
			JohnNPC: {
				Angry: Это МОЯ шляпа! Верни её или я заберу силой!
				AngryChat: Джону не нравится, что вы носите его шляпу...
				Standard1: Пещеры... они меняют человека. Поверь мне.
				Standard2: Я видел тут такое, во что ты не поверишь.
				Standard3: Не обращай на меня внимания. Просто прохожу мимо.
			}

			MechanicMerriweatherNPC: {
				Standard1: Меня зовут Мерриуэзер. Если там провода — я починю.
				Standard2: Не трогай красный провод. Хотя, если очень хочется — дерзай.
				Standard3: Старый Механик пропал в подземелье. Зато у меня расценки ниже.
				Standard4: Активаторы, нажимные плиты, переключатели — у меня весь набор для забав.
				Standard5: Стена плоти пала, и вот я здесь. Совпадение? Вряд ли.
				Rare: Только между нами — один из Механических боссов прямо сейчас за нами наблюдает.
			}

			CowNPC: {
				Standard1: Муу... то есть, ФЫРК! Я БЫК, понятно?!
				Standard2: Хватит называть меня коровой. Я ПОХОЖ на корову?! ...Не отвечай.
				Standard3: Я БЫК. Б-Ы-К. Рога? Чисто декоративные. Вымя? ...Не твоё дело.
				Standard4: Да, я даю молоко. Быки тоже так могут. На дворе 2026, хватит осуждать.
				Standard5: Проводник опять пытается меня погладить. Ещё раз и я его забодаю.
				Standard6: Я пришёл сюда только потому, что учуял сено. Не обольщайся.
				Cooldown: Эй-эй, полегче! Я не машина. Дай мне минутку...
				Milk1: Вот. Доволен? ...Не смотри на меня так.
				Milk2: *неловкое мычание* ...Мы об этом никогда не будем говорить.
				Milk3: Бычье молоко — деликатес в некоторых культурах! ...Наверное.
				Milk4: Клянусь, это последний раз. ...Я так говорил и в прошлый раз.
			}
		}

		Bestiary: {
			CowNPC: "'Корова', которая утверждает, что она бык. Даёт молоко, если у вас есть сено. Не спрашивайте, откуда оно берётся."
			JohnNPC: Суровый старик, бродящий по пещерам в одиночку. Очень привязан к своей шляпе. Не носите её при нём.
			MechanicMerriweatherNPC: Странствующий техник, заселяющийся после падения Стены плоти. Торгует гаечными ключами, проводом и достаточным количеством нажимных плит, чтобы испортить кому-нибудь день.
		}

		Items: {
			ibp3000: {
				DisplayName: ИБП-3000
				Tooltip:
					'''
					Метательный блок питания, потрескивающий чистым электричеством
					Наносит 69 урона и бьёт током при попадании
					'Защита от перенапряжения? Не слышал.'
					'''
			}

			VxeMouse: {
				DisplayName: VXE R1 SE+
				Tooltip:
					'''
					Магическая игровая мышь, которая летает за твоим курсором
					Дрожит, бьёт врагов и разлетается при сильном ударе
					Не может проходить сквозь стены
					'8000 Гц чистого дофамина'
					'''
			}

			SpookyCandy: {
				DisplayName: Жуткая конфета
				Tooltip:
					'''
					Совершенно обычная конфетка. Не о чем беспокоиться!
					'На вкус как счастье и радуга'
					'''
			}

			FatBurger: {
				DisplayName: Бургер жирности
				Tooltip:
					'''
					Подозрительно большой бургер, сочащийся жиром
					Восстанавливает 30 ХП при использовании
					'Ещё один не повредит, да?'
					'''
			}

			DietPill: {
				DisplayName: Диетическая таблетка
				Tooltip:
					'''
					Помогает вернуться в форму
					'Проконсультируйтесь с врачом перед применением'
					'''
			}

			Cherry: {
				DisplayName: Вишня
				Tooltip:
					'''
					Крайне редкая вишня, полностью восстанавливающая ХП
					'Один укус — и ты снова в строю'
					'''
			}

			JohnsHat: {
				DisplayName: Шапка Джона
				Tooltip:
					'''
					'Поношенная кепка с историей...'
					+10% урона по всем врагам
					+5% шанс критического удара
					Джон будет охотиться на тебя, если наденешь это...
					'''
			}

			CursedBandle: {
				DisplayName: Проклятый браслет
				Tooltip:
					'''
					'Ты чувствуешь, как что-то тёмное берёт контроль...'
					Проклятие утраты
					Твоё тело двигается само по себе
					'''
			}

			SlimeShotgun: {
				DisplayName: Слизневый дробовик
				Tooltip:
					'''
					Выстреливает очередью из 5 липких слизневых сгустков
					Слизь создаёт лужи на поверхностях, замедляющие врагов
					Прямые попадания также замедляют на 2 секунды
					Не требует боеприпасов
					'Кто это зарядил?!'
					'''
			}

			SlimeMinigun: {
				DisplayName: Слизневый миниган
				Tooltip:
					'''
					Быстро стреляет липкими слизневыми сгустками
					Слизь создаёт лужи на поверхностях, замедляющие врагов
					Не требует боеприпасов
					'Бррррр... *шлёп шлёп шлёп*'
					'''
			}

			CowBell: {
				DisplayName: Коровий колокольчик
				Tooltip: "'Позвоните, чтобы призвать корову... или быка?'"
			}

			CowMilk: {
				DisplayName: Молоко
				Tooltip:
					'''
					Просто обычное молоко, наверное.....
					Восстанавливает 50 ХП и даёт эффект Сытости
					'Не спрашивай, откуда оно'
					'''
			}

			OppressorMK2Item: {
				DisplayName: Угнетатель MK2
				Tooltip:
					'''
					Вызывает «Угнетателя MK2» — стильный, явно-не-угнанный летательный аппарат
					Бесконечный полёт и иммунитет к урону от падения
					Двойной тап ←/→ — рывок вперёд (перезарядка 5 секунд)
					Под персонажем во время езды появляется шкала перезарядки рывка
					'Произведено в месте, которого нет, компанией, которая отрицает своё существование'
					'''
			}

			GravityGun: {
				// Tooltip: ""
				// DisplayName: Gravity Gun
			}
		}

		Buffs: {
			CherryCooldown: {
				DisplayName: Откат вишни
				Description: Ты ещё не можешь съесть вишню...
			}

			CowBellCooldown: {
				DisplayName: Откат коровы
				Description: Корове нужно перевести дух перед следующим призывом...
			}

			OppressorMK2Buff: {
				DisplayName: Угнетатель MK2
				Description: Вы парите на «Угнетателе MK2».
			}
		}

		Misc: {
			VxeShattered: VXE разбита!
			MegaHeal: Конфета наполняет тебя невероятной энергией!
			CandyExplosion: Конфета... была петардой?!
			CandyDeathReason: "{0} зря съел эту конфету..."
			CowBellSpawn: Появилась корова!
			CowBellCooldownMsg: Корова ещё не отошла. Хватит звонить!
			JohnTransform: С Джона ХВАТИТ!
			BurgerEat0: Восхитительный бургер!
			BurgerEat30: Ты начинаешь полнеть.
			BurgerEat60: Ты чувствуешь себя очень тяжёлым.
			BurgerEat90: Ты еле двигаешься...
			DietPillUse: Стало легче!
			FatLostOnDeath: Ты немного похудел! (-{0})
			BurningFat: Сжигаем жир! ({0}/{1})
		}

		CandyJokes: {
			Joke1: Почему конфета пошла в школу? Хотела стать умной!
			Joke2: Как называется поющая конфета? Обёртышка!
			Joke3: Почему конфеты всегда проигрывают споры? Их всегда облизывают!
			Joke4: Какой танец любят конфеты? Карамель-стрит-степ!
			Joke5: Почему конфета круто играет в бейсбол? Она настоящий сосунок!
			Joke6: Что одна конфета сказала другой? 'Мы попали в липкую ситуацию!'
			Joke7: Зачем мармеладный мишка пошёл к стоматологу? Потерял пломбу!
			Joke8: Как конфеты здороваются? 'Привет, моя сладкая!'
			Joke9: Какая любимая конфета у привидения? Жвачка БУ-блгам!
			Joke10: Почему леденец перешёл дорогу? Он прилип к курице!
			Joke11: Какая конфета вечно опаздывает? Шоко-ПОЗДНО!
			Joke12: Как называется медведь без зубов? Желейный мишка!
			Joke13: Какую музыку любят конфеты? Рэп... ну, обёрточный.
			Joke14: Тук-тук. Кто там? Конфета. Какая? Карамель-кончил-открывать!
			Joke15: Врач сказал мне бросить конфеты... самый сладкий совет, которым я не воспользовался.
			Joke16: Я однажды рассказал шутку про конфеты. Сладкая была, но подача — не разжуёшь.
			Joke17: Что сказала конфета перед смертью? 'Жизнь сладкая... слишком сладкая...'
			Joke18: Почему дроболом написал заявление в полицию? На него напал рот!
			Joke19: Я съел конфету, и она меня убила. Ну, хотя бы умер за любимым делом.
			Joke20: Мне говорили, что конфеты меня не убьют. Они лгали.
		}

		UI: {
			GrabMilk: Взять молоко

			FatBar: {
				Label: Жир: {0}/{1}
				Stage0: Норма
				Stage1: Полноват
				Stage2: Толстый
				Stage3: Ожирение
				Stage4: Морбидное ожирение
			}
		}

		Projectiles: {
			Ibp3000Projectile.DisplayName: ИБП-3000
			SlimeGlob.DisplayName: Слизневый сгусток
			SlimePuddle.DisplayName: Слизневая лужа
